   "source": [
    "# DataFrame de resultados\n",
    "resultados = pd.DataFrame({\n",
    "    'Classe': range(1, len(Lt) + 1),\n",
    "    'Lt (cm)': Lt,\n",
    "    'Freq': F,\n",
